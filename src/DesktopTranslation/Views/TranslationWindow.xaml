<Window x:Class="DesktopTranslation.Views.TranslationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DesktopTranslation"
        Width="720" Height="400"
        MinWidth="520" MinHeight="280"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <!-- Animation Storyboards -->
        <Storyboard x:Key="FadeInStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="MainBorder"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                             From="0.96" To="1.0" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="MainBorder"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             From="0.96" To="1.0" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="FadeOutStoryboard" Completed="FadeOut_Completed">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.1">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Translation Result Fade In -->
        <Storyboard x:Key="ResultFadeInStoryboard">
            <DoubleAnimation Storyboard.TargetName="TranslationTextBox"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Shimmer Animation -->
        <Storyboard x:Key="ShimmerStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="ShimmerTranslate"
                             Storyboard.TargetProperty="X"
                             From="-200" To="400" Duration="0:0:1.5"/>
        </Storyboard>

        <!-- Icon Button Style -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}"
                                BorderBrush="Transparent" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource ButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource ButtonPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource AccentPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Segment Button Style -->
        <Style x:Key="SegmentButton" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}"
                                BorderBrush="Transparent" BorderThickness="1">
                            <Grid>
                                <Border x:Name="HoverOverlay" Background="White" Opacity="0"
                                        CornerRadius="4" Margin="-10,-3"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverOverlay" Property="Opacity" Value="0.12"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HoverOverlay" Property="Opacity" Value="0.06"/>
                                <Setter TargetName="HoverOverlay" Property="Background" Value="Black"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource AccentPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Main Border with Shadow -->
    <Border x:Name="MainBorder"
            CornerRadius="12"
            Background="{DynamicResource BgPrimaryBrush}"
            Margin="10"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform ScaleX="1" ScaleY="1"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" Opacity="0.15" ShadowDepth="6" Direction="270"/>
        </Border.Effect>
        <Border.Clip>
            <RectangleGeometry x:Name="ClipGeometry" RadiusX="12" RadiusY="12"/>
        </Border.Clip>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>      <!-- Title Bar -->
                <RowDefinition Height="*"/>       <!-- Content -->
                <RowDefinition Height="Auto"/>    <!-- History Panel -->
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="{DynamicResource BgSecondaryBrush}"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>     <!-- Drag area -->
                        <ColumnDefinition Width="Auto"/>  <!-- Engine Switch -->
                        <ColumnDefinition Width="Auto"/>  <!-- Pin -->
                        <ColumnDefinition Width="Auto"/>  <!-- Minimize -->
                        <ColumnDefinition Width="Auto"/>  <!-- Close -->
                    </Grid.ColumnDefinitions>

                    <!-- Drag area with title -->
                    <TextBlock Grid.Column="0" Text="DesktopTranslation"
                               VerticalAlignment="Center" Margin="14,0,0,0"
                               FontSize="12" FontWeight="Medium"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>

                    <!-- Segmented Control: Google | LLM -->
                    <Border Grid.Column="1" CornerRadius="6" Background="{DynamicResource SeparatorBrush}"
                            Margin="4" Padding="2" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="BtnGoogle" Content="Google"
                                    Click="EngineGoogle_Click"
                                    Style="{StaticResource SegmentButton}"
                                    ToolTip="Google 翻譯 (Alt+G)"
                                    Background="{DynamicResource SegmentActiveBrush}"
                                    Foreground="{DynamicResource SegmentActiveTextBrush}"/>
                            <Button x:Name="BtnLlm" Content="LLM"
                                    Click="EngineLlm_Click"
                                    Style="{StaticResource SegmentButton}"
                                    ToolTipService.ShowOnDisabled="True"
                                    Background="{DynamicResource SegmentInactiveBrush}"
                                    Foreground="{DynamicResource SegmentInactiveTextBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Pin Button -->
                    <Button Grid.Column="2" x:Name="BtnPin" Content="&#x1F4CC;"
                            Style="{StaticResource IconButton}" Click="Pin_Click"
                            ToolTip="置頂"/>

                    <!-- Minimize Button -->
                    <Button Grid.Column="3" Content="&#x2014;"
                            Style="{StaticResource IconButton}" Click="Minimize_Click"
                            ToolTip="最小化"/>

                    <!-- Close Button -->
                    <Button Grid.Column="4" Content="&#x2715;"
                            Style="{StaticResource IconButton}" Click="Close_Click"
                            ToolTip="關閉"/>
                </Grid>
            </Border>

            <!-- Content Area -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Language Selection Bar -->
                    <RowDefinition Height="*"/>      <!-- Text Areas -->
                </Grid.RowDefinitions>

                <!-- Language Selection Bar -->
                <Grid Grid.Row="0" Margin="16,8,16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>     <!-- Source group -->
                        <ColumnDefinition Width="Auto"/>  <!-- Swap button -->
                        <ColumnDefinition Width="*"/>     <!-- Target group -->
                    </Grid.ColumnDefinitions>

                    <!-- Source Language Group -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                HorizontalAlignment="Left" VerticalAlignment="Center">
                        <ComboBox x:Name="SourceLanguageCombo"
                                  FontSize="11" MinWidth="100" Height="22"
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  Background="Transparent" BorderThickness="0"
                                  SelectionChanged="SourceLanguageCombo_SelectionChanged"
                                  VerticalContentAlignment="Center"/>
                        <Button x:Name="BtnTtsSource" Content="&#x1F50A;"
                                Click="TtsSource_Click"
                                ToolTip="朗讀原文" Margin="4,0,0,0" FontSize="12">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=InputTextBox}" Value="">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="&#x2715;" Style="{StaticResource IconButton}"
                                Click="ClearInput_Click" ToolTip="清除"
                                FontSize="10" Margin="2,0,0,0"/>
                    </StackPanel>

                    <!-- Swap Button (centered) -->
                    <Button x:Name="BtnSwap" Grid.Column="1"
                            Content="&#x21C4;"
                            Click="SwapLanguages_Click"
                            ToolTip="互換語言 (Ctrl+L)"
                            Width="28" Height="28"
                            Margin="12,0"
                            FontSize="14" FontWeight="Bold"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            Background="{DynamicResource BgSecondaryBrush}"
                            BorderThickness="0" Cursor="Hand"
                            FocusVisualStyle="{x:Null}"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        CornerRadius="14" Padding="2"
                                        BorderBrush="Transparent" BorderThickness="2">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{DynamicResource AccentPrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{DynamicResource AccentActiveBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                        <Setter TargetName="Bd" Property="BorderBrush"
                                                Value="{DynamicResource AccentPrimaryBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Target Language Group -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                HorizontalAlignment="Left" VerticalAlignment="Center">
                        <ComboBox x:Name="TargetLanguageCombo"
                                  FontSize="11" MinWidth="100" Height="22"
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  Background="Transparent" BorderThickness="0"
                                  SelectionChanged="TargetLanguageCombo_SelectionChanged"
                                  VerticalContentAlignment="Center"/>
                        <Button x:Name="BtnTtsTarget" Content="&#x1F50A;"
                                Click="TtsTarget_Click"
                                ToolTip="朗讀翻譯" Margin="4,0,0,0" FontSize="12">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=TranslationTextBox}" Value="">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button x:Name="CopyResultButton" Content="&#x1F4CB;"
                                Click="CopyResult_Click" ToolTip="複製翻譯結果 (Ctrl+Shift+Insert)"
                                Margin="2,0,0,0" FontSize="12">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=TranslationTextBox}" Value="">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Separator line under language bar -->
                <Border Grid.Row="0" Height="1" VerticalAlignment="Bottom"
                        Background="{DynamicResource SeparatorBrush}" Margin="16,0"/>

                <!-- Text Areas -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1"/>   <!-- Pure separator -->
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Pane: Input -->
                    <Grid Grid.Column="0">
                        <TextBox x:Name="InputTextBox"
                                 Margin="16,10,12,10"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 CaretBrush="{DynamicResource TextPrimaryBrush}"
                                 SelectionBrush="{DynamicResource AccentPrimaryBrush}"
                                 FontFamily="Segoe UI" FontSize="14"
                                 Block.LineHeight="22.4"
                                 TextChanged="InputTextBox_TextChanged"
                                 Padding="0"/>
                        <TextBlock Text="輸入或貼上文字…"
                                   Margin="16,10,12,10"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="14"
                                   LineHeight="22.4"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Top"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=InputTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <!-- Focus underline (aligned to TextBox bottom edge via Margin mirroring TextBox Margin) -->
                        <Border Height="2" VerticalAlignment="Bottom"
                                Margin="16,0,12,10"
                                Background="{DynamicResource AccentPrimaryBrush}"
                                IsHitTestVisible="False">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Opacity" Value="0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=InputTextBox}" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                    </Grid>

                    <!-- Vertical Separator -->
                    <Border Grid.Column="1" Background="{DynamicResource SeparatorBrush}"
                            Width="1" HorizontalAlignment="Center"/>

                    <!-- Right Pane: Translation -->
                    <Grid Grid.Column="2" Margin="12,10,16,10">
                        <!-- Shimmer Loading Skeleton -->
                        <StackPanel x:Name="ShimmerPanel" Visibility="Collapsed" Margin="0,0,0,0">
                            <StackPanel.Resources>
                                <LinearGradientBrush x:Key="ShimmerOpacityMask" StartPoint="0,0.5" EndPoint="1,0.5">
                                    <LinearGradientBrush.Transform>
                                        <TranslateTransform x:Name="ShimmerTranslate" X="-200"/>
                                    </LinearGradientBrush.Transform>
                                    <GradientStop Color="#40000000" Offset="0"/>
                                    <GradientStop Color="#80000000" Offset="0.5"/>
                                    <GradientStop Color="#40000000" Offset="1"/>
                                </LinearGradientBrush>
                            </StackPanel.Resources>
                            <Border Height="14" CornerRadius="4" Background="{DynamicResource ShimmerBaseBrush}"
                                    Margin="0,0,40,8" Opacity="0.6"
                                    OpacityMask="{StaticResource ShimmerOpacityMask}"/>
                            <Border Height="14" CornerRadius="4" Background="{DynamicResource ShimmerBaseBrush}"
                                    Margin="0,0,20,8" Opacity="0.6"
                                    OpacityMask="{StaticResource ShimmerOpacityMask}"/>
                            <Border Height="14" CornerRadius="4" Background="{DynamicResource ShimmerBaseBrush}"
                                    Margin="0,0,60,8" Opacity="0.6"
                                    OpacityMask="{StaticResource ShimmerOpacityMask}"/>
                        </StackPanel>

                        <!-- Error Display -->
                        <StackPanel x:Name="ErrorPanel" Visibility="Collapsed" Margin="0,0,0,0">
                            <TextBlock x:Name="ErrorText" Foreground="{DynamicResource ErrorBrush}"
                                       TextWrapping="Wrap" FontSize="13"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Margin="0,0,12,0">
                                    <Hyperlink Click="Retry_Click"
                                               Foreground="{DynamicResource AccentPrimaryBrush}"
                                               ToolTip="重試翻譯 (F5)">
                                        重試
                                    </Hyperlink>
                                </TextBlock>
                                <TextBlock x:Name="OpenSettingsActionText" Visibility="Collapsed">
                                    <Hyperlink Click="OpenSettings_Click"
                                               Foreground="{DynamicResource AccentPrimaryBrush}">
                                        開啟設定
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>

                        <!-- Focus underline (aligned to pane bottom — mirrors Input side for symmetry, no negative margin to avoid collision with HistoryPanel separator) -->
                        <Border Height="2" VerticalAlignment="Bottom"
                                Margin="0,0,0,0"
                                Background="{DynamicResource AccentPrimaryBrush}"
                                IsHitTestVisible="False">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Opacity" Value="0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=TranslationTextBox}" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>

                        <!-- Translation Text -->
                        <TextBox x:Name="TranslationTextBox"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 CaretBrush="{DynamicResource TextPrimaryBrush}"
                                 SelectionBrush="{DynamicResource AccentPrimaryBrush}"
                                 FontFamily="Segoe UI" FontSize="14"
                                 Block.LineHeight="22.4"
                                 Padding="0"/>
                    </Grid>
                </Grid>
            </Grid>

            <!-- History Panel -->
            <Border Grid.Row="2" Background="{DynamicResource BgSecondaryBrush}"
                    BorderBrush="{DynamicResource SeparatorBrush}" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,12,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Toggle row: toggle button + clear action -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Click="ToggleHistory_Click"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Padding="14,7"
                                Background="Transparent" BorderThickness="0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}" CornerRadius="0,0,0,12">
                                        <ContentPresenter HorizontalAlignment="Left"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background"
                                                    Value="{DynamicResource ButtonHoverBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="HistoryArrow" Text="&#x25B2;" FontSize="9"
                                           Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                                           Margin="0,0,6,0"/>
                                <TextBlock x:Name="HistoryLabel" Text="歷史紀錄 (0 筆)"
                                           FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Button>

                        <!-- Clear-all button (only visible when history panel is expanded).
                             Inline template so hover bg CornerRadius aligns with outer HistoryPanel
                             bottom-right 12px, avoiding 6px/12px mismatch at clip edge. -->
                        <Button Grid.Column="1" x:Name="BtnClearHistory"
                                Click="ClearHistory_Click"
                                Content="&#x1F5D1;"
                                ToolTip="清空歷史"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                FontSize="14" Padding="14,7"
                                FocusVisualStyle="{x:Null}"
                                Visibility="Collapsed">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}"
                                            CornerRadius="0,0,12,0"
                                            BorderBrush="Transparent" BorderThickness="1">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background"
                                                    Value="{DynamicResource ButtonHoverBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsKeyboardFocused" Value="True">
                                            <Setter TargetName="Bd" Property="BorderBrush"
                                                    Value="{DynamicResource AccentPrimaryBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.35"/>
                                            <Setter Property="Cursor" Value="Arrow"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- History List -->
                    <!-- Empty-state (shown when panel expanded but list is empty) -->
                    <TextBlock x:Name="HistoryEmptyState" Grid.Row="1"
                               Text="尚無翻譯紀錄"
                               FontSize="12"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Margin="0,32"
                               Visibility="Collapsed"/>

                    <ListBox x:Name="HistoryListBox" Grid.Row="1"
                             Visibility="Collapsed" MaxHeight="200"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionChanged="HistoryListBox_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="14,6"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="Transparent"
                                                    Padding="{TemplateBinding Padding}"
                                                    CornerRadius="4" Margin="4,1"
                                                    BorderBrush="Transparent" BorderThickness="1">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background"
                                                            Value="{DynamicResource ButtonHoverBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background"
                                                            Value="{DynamicResource AccentSubtleBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                                    <Setter TargetName="Bd" Property="BorderBrush"
                                                            Value="{DynamicResource AccentPrimaryBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <!-- Row 0: Source → Translated -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding SourceText}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12"/>
                                        <TextBlock Grid.Column="1" Text=" → " Margin="6,0"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                        <TextBlock Grid.Column="2" Text="{Binding TranslatedText}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{DynamicResource AccentPrimaryBrush}" FontSize="12"/>
                                    </Grid>
                                    <!-- Row 1: meta (time · engine), right-aligned small.
                                         TimestampDisplay shows HH:mm same-day, MM/dd HH:mm else.
                                         EngineDisplay title-cases "google" → "Google", "llm" → "LLM". -->
                                    <StackPanel Grid.Row="1" Orientation="Horizontal"
                                                HorizontalAlignment="Right" Margin="0,2,0,0">
                                        <TextBlock Text="{Binding TimestampDisplay}" FontSize="10"
                                                   Foreground="{DynamicResource TextTertiaryBrush}"/>
                                        <TextBlock Text=" · " Margin="4,0" FontSize="10"
                                                   Foreground="{DynamicResource TextTertiaryBrush}"/>
                                        <TextBlock Text="{Binding EngineDisplay}" FontSize="10"
                                                   Foreground="{DynamicResource TextTertiaryBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
