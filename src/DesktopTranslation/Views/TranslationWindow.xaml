<Window x:Class="DesktopTranslation.Views.TranslationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DesktopTranslation"
        Width="720" Height="400"
        MinWidth="520" MinHeight="280"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <!-- Animation Storyboards -->
        <Storyboard x:Key="FadeInStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="MainBorder"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                             From="0.96" To="1.0" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="MainBorder"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             From="0.96" To="1.0" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="FadeOutStoryboard" Completed="FadeOut_Completed">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.1">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Translation Result Fade In -->
        <Storyboard x:Key="ResultFadeInStoryboard">
            <DoubleAnimation Storyboard.TargetName="TranslationTextBox"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Shimmer Animation -->
        <Storyboard x:Key="ShimmerStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="ShimmerTranslate"
                             Storyboard.TargetProperty="X"
                             From="-200" To="400" Duration="0:0:1.5"/>
        </Storyboard>

        <!-- Icon Button Style -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource ButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource ButtonPressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Segment Button Style -->
        <Style x:Key="SegmentButton" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Main Border with Shadow -->
    <Border x:Name="MainBorder"
            CornerRadius="12"
            Background="{DynamicResource BgPrimaryBrush}"
            Margin="10"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform ScaleX="1" ScaleY="1"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" Opacity="0.15" ShadowDepth="6" Direction="270"/>
        </Border.Effect>
        <Border.Clip>
            <RectangleGeometry x:Name="ClipGeometry" RadiusX="12" RadiusY="12"/>
        </Border.Clip>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>      <!-- Title Bar -->
                <RowDefinition Height="*"/>       <!-- Content -->
                <RowDefinition Height="Auto"/>    <!-- History Panel -->
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="{DynamicResource BgSecondaryBrush}"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>     <!-- Drag area -->
                        <ColumnDefinition Width="Auto"/>  <!-- Engine Switch -->
                        <ColumnDefinition Width="Auto"/>  <!-- Pin -->
                        <ColumnDefinition Width="Auto"/>  <!-- Minimize -->
                        <ColumnDefinition Width="Auto"/>  <!-- Close -->
                    </Grid.ColumnDefinitions>

                    <!-- Drag area with title -->
                    <TextBlock Grid.Column="0" Text="DesktopTranslation"
                               VerticalAlignment="Center" Margin="14,0,0,0"
                               FontSize="12" FontWeight="Medium"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>

                    <!-- Segmented Control: Google | LLM -->
                    <Border Grid.Column="1" CornerRadius="6" Background="{DynamicResource SeparatorBrush}"
                            Margin="4" Padding="2" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="BtnGoogle" Content="Google"
                                    Click="EngineGoogle_Click"
                                    Style="{StaticResource SegmentButton}"
                                    Background="{DynamicResource SegmentActiveBrush}"
                                    Foreground="{DynamicResource SegmentActiveTextBrush}"/>
                            <Button x:Name="BtnLlm" Content="LLM"
                                    Click="EngineLlm_Click"
                                    Style="{StaticResource SegmentButton}"
                                    Background="{DynamicResource SegmentInactiveBrush}"
                                    Foreground="{DynamicResource SegmentInactiveTextBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Pin Button -->
                    <Button Grid.Column="2" x:Name="BtnPin" Content="&#x1F4CC;"
                            Style="{StaticResource IconButton}" Click="Pin_Click"
                            ToolTip="置頂"/>

                    <!-- Minimize Button -->
                    <Button Grid.Column="3" Content="&#x2014;"
                            Style="{StaticResource IconButton}" Click="Minimize_Click"
                            ToolTip="最小化"/>

                    <!-- Close Button -->
                    <Button Grid.Column="4" Content="&#x2715;"
                            Style="{StaticResource IconButton}" Click="Close_Click"
                            ToolTip="關閉"/>
                </Grid>
            </Border>

            <!-- Content Area -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>   <!-- Separator -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Pane: Input -->
                <Grid Grid.Column="0" Margin="16,10,12,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Language Label Row -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock x:Name="SourceLanguageLabel" Text="偵測中..."
                                   FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="BtnTtsSource" Content="&#x1F50A;"
                                Style="{StaticResource IconButton}" Click="TtsSource_Click"
                                ToolTip="朗讀原文" Margin="4,0,0,0" FontSize="12"/>
                        <Button Content="&#x2715;" Style="{StaticResource IconButton}"
                                Click="ClearInput_Click" ToolTip="清除"
                                FontSize="10" Margin="2,0,0,0"/>
                    </StackPanel>

                    <!-- Input TextBox -->
                    <TextBox x:Name="InputTextBox" Grid.Row="1"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             CaretBrush="{DynamicResource TextPrimaryBrush}"
                             SelectionBrush="{DynamicResource AccentPrimaryBrush}"
                             FontFamily="Segoe UI" FontSize="14"
                             Block.LineHeight="22.4"
                             TextChanged="InputTextBox_TextChanged"
                             Padding="0"/>
                </Grid>

                <!-- Separator -->
                <Border Grid.Column="1" Background="{DynamicResource SeparatorBrush}" Width="1"/>

                <!-- Right Pane: Translation -->
                <Grid Grid.Column="2" Margin="12,10,16,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Language Label Row -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock x:Name="TargetLanguageLabel" Text="繁體中文"
                                   FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="BtnTtsTarget" Content="&#x1F50A;"
                                Style="{StaticResource IconButton}" Click="TtsTarget_Click"
                                ToolTip="朗讀翻譯" Margin="4,0,0,0" FontSize="12"/>
                        <Button Content="&#x1F4CB;" Style="{StaticResource IconButton}"
                                Click="CopyResult_Click" ToolTip="複製翻譯結果"
                                Margin="2,0,0,0" FontSize="12"/>
                    </StackPanel>

                    <!-- Translation Result -->
                    <Grid Grid.Row="1">
                        <!-- Shimmer Loading Skeleton -->
                        <StackPanel x:Name="ShimmerPanel" Visibility="Collapsed" Margin="0,8,0,0">
                            <StackPanel.Resources>
                                <LinearGradientBrush x:Key="ShimmerOpacityMask" StartPoint="0,0.5" EndPoint="1,0.5">
                                    <LinearGradientBrush.Transform>
                                        <TranslateTransform x:Name="ShimmerTranslate" X="-200"/>
                                    </LinearGradientBrush.Transform>
                                    <GradientStop Color="#40000000" Offset="0"/>
                                    <GradientStop Color="#80000000" Offset="0.5"/>
                                    <GradientStop Color="#40000000" Offset="1"/>
                                </LinearGradientBrush>
                            </StackPanel.Resources>
                            <Border Height="14" CornerRadius="4" Background="{DynamicResource ShimmerBaseBrush}"
                                    Margin="0,0,40,8" Opacity="0.6"
                                    OpacityMask="{StaticResource ShimmerOpacityMask}"/>
                            <Border Height="14" CornerRadius="4" Background="{DynamicResource ShimmerBaseBrush}"
                                    Margin="0,0,20,8" Opacity="0.6"
                                    OpacityMask="{StaticResource ShimmerOpacityMask}"/>
                            <Border Height="14" CornerRadius="4" Background="{DynamicResource ShimmerBaseBrush}"
                                    Margin="0,0,60,8" Opacity="0.6"
                                    OpacityMask="{StaticResource ShimmerOpacityMask}"/>
                        </StackPanel>

                        <!-- Error Display -->
                        <StackPanel x:Name="ErrorPanel" Visibility="Collapsed" Margin="0,8,0,0">
                            <TextBlock x:Name="ErrorText" Foreground="{DynamicResource ErrorBrush}"
                                       TextWrapping="Wrap" FontSize="13"/>
                            <TextBlock Margin="0,4,0,0">
                                <Hyperlink Click="Retry_Click" Foreground="{DynamicResource AccentPrimaryBrush}">
                                    重試
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>

                        <!-- Translation Text -->
                        <TextBox x:Name="TranslationTextBox"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 CaretBrush="{DynamicResource TextPrimaryBrush}"
                                 SelectionBrush="{DynamicResource AccentPrimaryBrush}"
                                 FontFamily="Segoe UI" FontSize="14"
                                 Block.LineHeight="22.4"
                                 Padding="0"/>
                    </Grid>
                </Grid>
            </Grid>

            <!-- History Panel -->
            <Border Grid.Row="2" Background="{DynamicResource BgSecondaryBrush}"
                    BorderBrush="{DynamicResource SeparatorBrush}" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,12,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Toggle Button -->
                    <Button Grid.Row="0" Click="ToggleHistory_Click"
                            HorizontalAlignment="Stretch" Padding="14,7"
                            Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}" CornerRadius="0,0,12,12">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{DynamicResource ButtonHoverBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="HistoryArrow" Text="&#x25B2;" FontSize="9"
                                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                                       Margin="0,0,6,0"/>
                            <TextBlock x:Name="HistoryLabel" Text="歷史紀錄 (0 筆)"
                                       FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Button>

                    <!-- History List -->
                    <ListBox x:Name="HistoryListBox" Grid.Row="1"
                             Visibility="Collapsed" MaxHeight="200"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="14,6"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="Transparent"
                                                    Padding="{TemplateBinding Padding}"
                                                    CornerRadius="4" Margin="4,1">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background"
                                                            Value="{DynamicResource ButtonHoverBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding SourceText}"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12"/>
                                    <TextBlock Grid.Column="1" Text=" → " Margin="6,0"
                                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                    <TextBlock Grid.Column="2" Text="{Binding TranslatedText}"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource AccentPrimaryBrush}" FontSize="12"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
