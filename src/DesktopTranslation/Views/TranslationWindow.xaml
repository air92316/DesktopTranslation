<Window x:Class="DesktopTranslation.Views.TranslationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DesktopTranslation"
        Width="720" Height="400"
        MinWidth="520" MinHeight="280"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <!-- Light Theme Colors -->
        <SolidColorBrush x:Key="BgBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextBrush" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="SeparatorBrush" Color="#E5E5E5"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#0078D4"/>
        <SolidColorBrush x:Key="LabelBrush" Color="#888888"/>
        <SolidColorBrush x:Key="TitleBarBrush" Color="#F3F3F3"/>
        <SolidColorBrush x:Key="ButtonHoverBrush" Color="#E8E8E8"/>
        <SolidColorBrush x:Key="SegmentActiveBrush" Color="#0078D4"/>
        <SolidColorBrush x:Key="SegmentInactiveBrush" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="SegmentActiveTextBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SegmentInactiveTextBrush" Color="#555555"/>
        <SolidColorBrush x:Key="ShimmerBrush" Color="#E8E8E8"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#D32F2F"/>
        <SolidColorBrush x:Key="HistoryBgBrush" Color="#FAFAFA"/>

        <!-- Animation Storyboards -->
        <Storyboard x:Key="FadeInStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="MainBorder"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                             From="0.95" To="1.0" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="MainBorder"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             From="0.95" To="1.0" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="FadeOutStoryboard" Completed="FadeOut_Completed">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.1"/>
        </Storyboard>

        <!-- Shimmer Animation -->
        <Storyboard x:Key="ShimmerStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="ShimmerTranslate"
                             Storyboard.TargetProperty="X"
                             From="-200" To="400" Duration="0:0:1.5"/>
        </Storyboard>

        <!-- Button Style -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource LabelBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource ButtonHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Main Border with Shadow -->
    <Border x:Name="MainBorder"
            CornerRadius="12"
            Background="{DynamicResource BgBrush}"
            Margin="10"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform ScaleX="1" ScaleY="1"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.25" ShadowDepth="4" Direction="270"/>
        </Border.Effect>
        <Border.Clip>
            <RectangleGeometry x:Name="ClipGeometry" RadiusX="12" RadiusY="12"/>
        </Border.Clip>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>      <!-- Title Bar -->
                <RowDefinition Height="*"/>       <!-- Content -->
                <RowDefinition Height="Auto"/>    <!-- History Panel -->
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="{DynamicResource TitleBarBrush}"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>     <!-- Drag area -->
                        <ColumnDefinition Width="Auto"/>  <!-- Engine Switch -->
                        <ColumnDefinition Width="Auto"/>  <!-- Pin -->
                        <ColumnDefinition Width="Auto"/>  <!-- Minimize -->
                        <ColumnDefinition Width="Auto"/>  <!-- Close -->
                    </Grid.ColumnDefinitions>

                    <!-- Drag area with title -->
                    <TextBlock Grid.Column="0" Text="DesktopTranslation"
                               VerticalAlignment="Center" Margin="12,0,0,0"
                               FontSize="12" Foreground="{DynamicResource LabelBrush}"/>

                    <!-- Segmented Control: Google | LLM -->
                    <Border Grid.Column="1" CornerRadius="4" Background="{DynamicResource SeparatorBrush}"
                            Margin="4" Padding="1" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="BtnGoogle" Content="Google"
                                    Click="EngineGoogle_Click" Padding="8,2" FontSize="11"
                                    Background="{DynamicResource SegmentActiveBrush}"
                                    Foreground="{DynamicResource SegmentActiveTextBrush}"
                                    BorderThickness="0" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button x:Name="BtnLlm" Content="LLM"
                                    Click="EngineLlm_Click" Padding="8,2" FontSize="11"
                                    Background="{DynamicResource SegmentInactiveBrush}"
                                    Foreground="{DynamicResource SegmentInactiveTextBrush}"
                                    BorderThickness="0" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Pin Button -->
                    <Button Grid.Column="2" x:Name="BtnPin" Content="&#x1F4CC;"
                            Style="{StaticResource IconButton}" Click="Pin_Click"
                            ToolTip="置頂"/>

                    <!-- Minimize Button -->
                    <Button Grid.Column="3" Content="&#x2014;"
                            Style="{StaticResource IconButton}" Click="Minimize_Click"
                            ToolTip="最小化"/>

                    <!-- Close Button -->
                    <Button Grid.Column="4" Content="&#x2715;"
                            Style="{StaticResource IconButton}" Click="Close_Click"
                            ToolTip="關閉"/>
                </Grid>
            </Border>

            <!-- Content Area -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>   <!-- Separator -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Pane: Input -->
                <Grid Grid.Column="0" Margin="12,8,8,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Language Label Row -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock x:Name="SourceLanguageLabel" Text="偵測中..."
                                   FontSize="12" Foreground="{DynamicResource LabelBrush}"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="BtnTtsSource" Content="&#x1F50A;"
                                Style="{StaticResource IconButton}" Click="TtsSource_Click"
                                ToolTip="朗讀原文" Margin="4,0,0,0"/>
                        <Button Content="&#x2715;" Style="{StaticResource IconButton}"
                                Click="ClearInput_Click" ToolTip="清除"
                                FontSize="11" Margin="2,0,0,0"/>
                    </StackPanel>

                    <!-- Input TextBox -->
                    <TextBox x:Name="InputTextBox" Grid.Row="1"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="{DynamicResource TextBrush}"
                             FontFamily="Segoe UI" FontSize="14"
                             TextChanged="InputTextBox_TextChanged"
                             Padding="0"/>
                </Grid>

                <!-- Separator -->
                <Border Grid.Column="1" Background="{DynamicResource SeparatorBrush}" Width="1"/>

                <!-- Right Pane: Translation -->
                <Grid Grid.Column="2" Margin="8,8,12,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Language Label Row -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock x:Name="TargetLanguageLabel" Text="繁體中文"
                                   FontSize="12" Foreground="{DynamicResource LabelBrush}"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="BtnTtsTarget" Content="&#x1F50A;"
                                Style="{StaticResource IconButton}" Click="TtsTarget_Click"
                                ToolTip="朗讀翻譯" Margin="4,0,0,0"/>
                        <Button Content="&#x1F4CB;" Style="{StaticResource IconButton}"
                                Click="CopyResult_Click" ToolTip="複製翻譯結果"
                                Margin="2,0,0,0"/>
                    </StackPanel>

                    <!-- Translation Result -->
                    <Grid Grid.Row="1">
                        <!-- Shimmer Loading Skeleton -->
                        <StackPanel x:Name="ShimmerPanel" Visibility="Collapsed" Margin="0,8,0,0">
                            <Border Height="16" CornerRadius="4" Background="{DynamicResource ShimmerBrush}"
                                    Margin="0,0,40,8" Opacity="0.6">
                                <Border.OpacityMask>
                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                        <LinearGradientBrush.Transform>
                                            <TranslateTransform x:Name="ShimmerTranslate" X="-200"/>
                                        </LinearGradientBrush.Transform>
                                        <GradientStop Color="#40000000" Offset="0"/>
                                        <GradientStop Color="#80000000" Offset="0.5"/>
                                        <GradientStop Color="#40000000" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.OpacityMask>
                            </Border>
                            <Border Height="16" CornerRadius="4" Background="{DynamicResource ShimmerBrush}"
                                    Margin="0,0,20,8" Opacity="0.6"/>
                            <Border Height="16" CornerRadius="4" Background="{DynamicResource ShimmerBrush}"
                                    Margin="0,0,60,8" Opacity="0.6"/>
                        </StackPanel>

                        <!-- Error Display -->
                        <StackPanel x:Name="ErrorPanel" Visibility="Collapsed" Margin="0,8,0,0">
                            <TextBlock x:Name="ErrorText" Foreground="{DynamicResource ErrorBrush}"
                                       TextWrapping="Wrap" FontSize="13"/>
                            <TextBlock Margin="0,4,0,0">
                                <Hyperlink Click="Retry_Click" Foreground="{DynamicResource AccentBrush}">
                                    重試
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>

                        <!-- Translation Text -->
                        <TextBox x:Name="TranslationTextBox"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="{DynamicResource TextBrush}"
                                 FontFamily="Segoe UI" FontSize="14"
                                 Padding="0"/>
                    </Grid>
                </Grid>
            </Grid>

            <!-- History Panel -->
            <Border Grid.Row="2" Background="{DynamicResource HistoryBgBrush}"
                    BorderBrush="{DynamicResource SeparatorBrush}" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,12,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Toggle Button -->
                    <Button Grid.Row="0" Click="ToggleHistory_Click"
                            HorizontalAlignment="Stretch" Padding="12,6"
                            Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="HistoryArrow" Text="&#x25B2;" FontSize="10"
                                       Foreground="{DynamicResource LabelBrush}" VerticalAlignment="Center"
                                       Margin="0,0,6,0"/>
                            <TextBlock x:Name="HistoryLabel" Text="歷史紀錄 (0 筆)"
                                       FontSize="12" Foreground="{DynamicResource LabelBrush}"/>
                        </StackPanel>
                    </Button>

                    <!-- History List -->
                    <ListBox x:Name="HistoryListBox" Grid.Row="1"
                             Visibility="Collapsed" MaxHeight="200"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="8,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding SourceText}"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource TextBrush}" FontSize="12"/>
                                    <TextBlock Grid.Column="1" Text=" → " Margin="4,0"
                                               Foreground="{DynamicResource LabelBrush}" FontSize="12"/>
                                    <TextBlock Grid.Column="2" Text="{Binding TranslatedText}"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource AccentBrush}" FontSize="12"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
