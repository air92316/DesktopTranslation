<Window x:Class="DesktopTranslation.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DesktopTranslation - 設定"
        Width="420" Height="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="SectionHeader">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,12,0,6"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="FieldLabel">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,6,0,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Translation Engine -->
                <TextBlock Text="翻譯引擎" Style="{StaticResource SectionHeader}"/>
                <RadioButton x:Name="RbGoogle" Content="Google Translate (免費)" GroupName="Engine" IsChecked="True" Margin="0,4"/>
                <RadioButton x:Name="RbLlm" Content="LLM (需要 API Key)" GroupName="Engine" Margin="0,4"/>

                <!-- LLM Provider -->
                <TextBlock Text="LLM 提供者" Style="{StaticResource FieldLabel}"/>
                <ComboBox x:Name="CbProvider" SelectedIndex="0" Width="200" HorizontalAlignment="Left">
                    <ComboBoxItem Content="Claude"/>
                    <ComboBoxItem Content="OpenAI"/>
                </ComboBox>

                <!-- API Key -->
                <TextBlock Text="API Key" Style="{StaticResource FieldLabel}"/>
                <PasswordBox x:Name="TxtApiKey" MaxLength="200" Width="300" HorizontalAlignment="Left"/>

                <!-- Separator -->
                <Separator Margin="0,12"/>

                <!-- Auto Start -->
                <CheckBox x:Name="ChkAutoStart" Content="開機自啟動" Margin="0,6"/>

                <!-- Double Tap Interval -->
                <TextBlock Style="{StaticResource FieldLabel}">
                    <Run Text="雙擊間隔："/>
                    <Run x:Name="TxtIntervalValue" Text="400"/>
                    <Run Text="ms"/>
                </TextBlock>
                <Slider x:Name="SliderInterval" Minimum="200" Maximum="800"
                        Value="400" TickFrequency="50" IsSnapToTickEnabled="True"
                        Width="300" HorizontalAlignment="Left"
                        ValueChanged="SliderInterval_ValueChanged"/>

                <!-- TTS Speed -->
                <TextBlock Style="{StaticResource FieldLabel}">
                    <Run Text="TTS 語速："/>
                    <Run x:Name="TxtSpeedValue" Text="1.0"/>
                </TextBlock>
                <Slider x:Name="SliderSpeed" Minimum="0.5" Maximum="2.0"
                        Value="1.0" TickFrequency="0.1" IsSnapToTickEnabled="True"
                        Width="300" HorizontalAlignment="Left"
                        ValueChanged="SliderSpeed_ValueChanged"/>

                <!-- Theme -->
                <TextBlock Text="主題" Style="{StaticResource FieldLabel}"/>
                <ComboBox x:Name="CbTheme" SelectedIndex="0" Width="200" HorizontalAlignment="Left">
                    <ComboBoxItem Content="跟隨系統" Tag="system"/>
                    <ComboBoxItem Content="淺色" Tag="light"/>
                    <ComboBoxItem Content="深色" Tag="dark"/>
                </ComboBox>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="取消" Width="80" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="儲存" Width="80" Click="Save_Click" IsDefault="True"
                    Background="#0078D4" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
