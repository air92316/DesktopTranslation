<Window x:Class="DesktopTranslation.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DesktopTranslation - 設定"
        Width="440" Height="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Section Header -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Field Label -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Card Container -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BgCardBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SeparatorStrongBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Themed RadioButton -->
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Themed CheckBox -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Themed ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
        </Style>

        <!-- Themed PasswordBox -->
        <Style TargetType="PasswordBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
        </Style>

        <!-- Themed TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
        </Style>

        <!-- Hint Text -->
        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <!-- Warning Text -->
        <Style x:Key="WarningText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <!-- Primary Button -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentPrimaryBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextInverseBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}"
                                BorderBrush="Transparent" BorderThickness="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource AccentActiveBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource AccentPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SeparatorStrongBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource ButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource ButtonPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource AccentPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Main Border with Shadow -->
    <Border CornerRadius="8" Background="{DynamicResource BgPrimaryBrush}" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" Opacity="0.08" ShadowDepth="4" Direction="270"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>    <!-- Title Bar -->
                <RowDefinition Height="*"/>     <!-- Content -->
                <RowDefinition Height="Auto"/>  <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="{DynamicResource BgSecondaryBrush}"
                    CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="設定" VerticalAlignment="Center" Margin="16,0,0,0"
                               FontSize="13" FontWeight="Medium"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <Button HorizontalAlignment="Right" Content="&#x2715;"
                            Margin="0,0,4,0" Click="Cancel_Click"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            FontSize="14" Cursor="Hand" Padding="8,4">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent"
                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{DynamicResource ButtonHoverBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          Margin="16,12,16,0">
                <StackPanel>
                    <!-- Translation Engine Card -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="翻譯引擎" Style="{StaticResource SectionHeader}"/>
                            <RadioButton x:Name="RbGoogle" Content="Google Translate (免費)"
                                         GroupName="Engine" IsChecked="True"/>
                            <RadioButton x:Name="RbLlm" Content="LLM (需要 API Key)"
                                         GroupName="Engine"/>
                        </StackPanel>
                    </Border>

                    <!-- LLM Settings Card -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="LLM 設定" Style="{StaticResource SectionHeader}"/>

                            <TextBlock Text="提供者" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="CbProvider" SelectedIndex="0" Width="200"
                                      HorizontalAlignment="Left" Margin="0,0,0,10"
                                      SelectionChanged="CbProvider_SelectionChanged">
                                <ComboBoxItem Content="Claude" Tag="claude"/>
                                <ComboBoxItem Content="OpenAI" Tag="openai"/>
                                <ComboBoxItem Content="Gemini (Phase 2b 即將支援)" Tag="gemini"
                                              IsEnabled="False"
                                              ToolTip="Gemini 提供者將於下個 Phase 2b 加入"/>
                            </ComboBox>

                            <TextBlock Text="Model" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="CbModel" Width="320"
                                      HorizontalAlignment="Left" Margin="0,0,0,8"
                                      DisplayMemberPath="DisplayName"
                                      SelectionChanged="CbModel_SelectionChanged"/>
                            <TextBox x:Name="TxtCustomModel" MaxLength="100" Width="320"
                                     HorizontalAlignment="Left" Margin="0,0,0,10"
                                     Visibility="Collapsed"
                                     ToolTip="輸入自訂 model id，例如 OpenRouter / Ollama 模型名稱"/>

                            <TextBlock Text="API Key" Style="{StaticResource FieldLabel}"/>
                            <PasswordBox x:Name="TxtApiKey" MaxLength="200" Width="320"
                                         HorizontalAlignment="Left" Margin="0,0,0,10"/>

                            <StackPanel x:Name="PnlBaseUrl" Visibility="Collapsed">
                                <TextBlock Text="Base URL（選填）" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtBaseUrl" MaxLength="200" Width="320"
                                         HorizontalAlignment="Left"/>
                                <TextBlock Style="{StaticResource HintText}"
                                           Text="留空使用預設；可填 OpenRouter / Groq 等 OpenAI 相容服務。"/>
                                <TextBlock Style="{StaticResource WarningText}"
                                           Text="⚠ 此 URL 將收到您的 API key，請只填您信任的服務。"/>
                            </StackPanel>

                            <Expander x:Name="ExpAdvanced" Header="進階設定（Temperature / MaxTokens）"
                                      IsExpanded="False" Margin="0,12,0,0"
                                      Foreground="{DynamicResource TextPrimaryBrush}">
                                <StackPanel Margin="0,8,0,0">
                                    <TextBlock Style="{StaticResource FieldLabel}">
                                        <Run Text="Temperature："/>
                                        <Run x:Name="TxtTemperatureValue" Text="0.3"/>
                                    </TextBlock>
                                    <Slider x:Name="SliderTemperature" Minimum="0.0" Maximum="2.0"
                                            Value="0.3" TickFrequency="0.1" IsSnapToTickEnabled="True"
                                            Width="300" HorizontalAlignment="Left" Margin="0,0,0,12"
                                            ValueChanged="SliderTemperature_ValueChanged"/>

                                    <TextBlock Style="{StaticResource FieldLabel}">
                                        <Run Text="Max Tokens："/>
                                        <Run x:Name="TxtMaxTokensValue" Text="2048"/>
                                    </TextBlock>
                                    <Slider x:Name="SliderMaxTokens" Minimum="256" Maximum="8192"
                                            Value="2048" TickFrequency="256" IsSnapToTickEnabled="True"
                                            Width="300" HorizontalAlignment="Left" Margin="0,0,0,8"
                                            ValueChanged="SliderMaxTokens_ValueChanged"/>

                                    <Button Content="重設預設值" Width="120" HorizontalAlignment="Left"
                                            Style="{StaticResource SecondaryButton}"
                                            Click="ResetAdvanced_Click"/>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </Border>

                    <!-- General Settings Card -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="一般" Style="{StaticResource SectionHeader}"/>
                            <CheckBox x:Name="ChkAutoStart" Content="開機自啟動" Margin="0,0,0,6"/>
                            <CheckBox x:Name="ChkAutoUpdate" Content="自動檢查更新" Margin="0,0,0,12"/>

                            <TextBlock Style="{StaticResource FieldLabel}">
                                <Run Text="雙擊間隔："/>
                                <Run x:Name="TxtIntervalValue" Text="400"/>
                                <Run Text="ms"/>
                            </TextBlock>
                            <Slider x:Name="SliderInterval" Minimum="200" Maximum="800"
                                    Value="400" TickFrequency="50" IsSnapToTickEnabled="True"
                                    Width="300" HorizontalAlignment="Left" Margin="0,0,0,12"
                                    ValueChanged="SliderInterval_ValueChanged"/>

                            <TextBlock Style="{StaticResource FieldLabel}">
                                <Run Text="TTS 語速："/>
                                <Run x:Name="TxtSpeedValue" Text="1.0"/>
                            </TextBlock>
                            <Slider x:Name="SliderSpeed" Minimum="0.5" Maximum="2.0"
                                    Value="1.0" TickFrequency="0.1" IsSnapToTickEnabled="True"
                                    Width="300" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                    <!-- Theme Card -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="外觀" Style="{StaticResource SectionHeader}"/>
                            <TextBlock Text="主題" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="CbTheme" SelectedIndex="0" Width="200"
                                      HorizontalAlignment="Left">
                                <ComboBoxItem Content="跟隨系統" Tag="system"/>
                                <ComboBoxItem Content="淺色" Tag="light"/>
                                <ComboBoxItem Content="深色" Tag="dark"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Action Buttons -->
            <Border Grid.Row="2" Padding="16,10,16,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="取消" Width="100" Margin="0,0,8,0" IsCancel="True"
                            Style="{StaticResource SecondaryButton}" Click="Cancel_Click"/>
                    <Button x:Name="BtnSave" Content="儲存" Width="100" IsDefault="True"
                            Style="{StaticResource PrimaryButton}" Click="Save_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
