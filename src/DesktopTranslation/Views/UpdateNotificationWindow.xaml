<Window x:Class="DesktopTranslation.Views.UpdateNotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DesktopTranslation - 軟體更新"
        Width="420" Height="380"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Primary Button -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentPrimaryBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextInverseBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}"
                                BorderBrush="Transparent" BorderThickness="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource AccentPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SeparatorStrongBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource ButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource AccentPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Main Border with Shadow -->
    <Border CornerRadius="12" Background="{DynamicResource BgPrimaryBrush}" Margin="10"
            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" Opacity="0.15" ShadowDepth="6" Direction="270"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>    <!-- Title Bar -->
                <RowDefinition Height="*"/>     <!-- Content -->
                <RowDefinition Height="Auto"/>  <!-- Progress -->
                <RowDefinition Height="Auto"/>  <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="{DynamicResource BgSecondaryBrush}"
                    CornerRadius="12,12,0,0">
                <Grid>
                    <TextBlock Text="軟體更新" VerticalAlignment="Center" Margin="16,0,0,0"
                               FontSize="13" FontWeight="Medium"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <Button HorizontalAlignment="Right" Content="&#x2715;"
                            Margin="0,0,4,0" Click="Close_Click"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            FontSize="14" Cursor="Hand" Padding="8,4">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent"
                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{DynamicResource ButtonHoverBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="20,16,20,0">
                <!-- Title -->
                <TextBlock Text="發現新版本" FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                <!-- Version Info -->
                <Border Background="{DynamicResource BgCardBrush}" CornerRadius="8" Padding="14,10"
                        BorderBrush="{DynamicResource SeparatorStrongBrush}" BorderThickness="1"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="目前版本" FontSize="11"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtCurrentVersion" Text="v1.1.0" FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="&#x2192;" FontSize="16"
                                   VerticalAlignment="Center" Margin="12,0"
                                   Foreground="{DynamicResource TextTertiaryBrush}"/>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="新版本" FontSize="11"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtNewVersion" Text="v1.2.0" FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentPrimaryBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Release Notes -->
                <TextBlock Text="更新內容" FontSize="12" FontWeight="Medium"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <Border Background="{DynamicResource BgCardBrush}" CornerRadius="6" Padding="10,8"
                        BorderBrush="{DynamicResource SeparatorBrush}" BorderThickness="1"
                        MaxHeight="100">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="TxtReleaseNotes" TextWrapping="Wrap" FontSize="12"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Text="載入中..."/>
                    </ScrollViewer>
                </Border>

                <!-- File Size -->
                <TextBlock x:Name="TxtFileSize" FontSize="11" Margin="0,6,0,0"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           Text="檔案大小：計算中..."/>
            </StackPanel>

            <!-- Progress Bar (hidden by default) -->
            <StackPanel x:Name="ProgressPanel" Grid.Row="2" Margin="20,8,20,0"
                        Visibility="Collapsed">
                <Grid Margin="0,0,0,4">
                    <TextBlock x:Name="TxtProgressStatus" Text="下載中..."
                               FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock x:Name="TxtProgressPercent" Text="0%"
                               FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Right"/>
                </Grid>
                <ProgressBar x:Name="DownloadProgress" Height="6" Minimum="0" Maximum="100"
                             Value="0" Foreground="{DynamicResource AccentPrimaryBrush}"
                             Background="{DynamicResource BgTertiaryBrush}"
                             AutomationProperties.Name="下載進度"/>
                <Button x:Name="BtnCancelDownload" Content="取消下載" Margin="0,8,0,0"
                        HorizontalAlignment="Right"
                        Style="{StaticResource SecondaryButton}" Click="CancelDownload_Click"/>
            </StackPanel>

            <!-- Action Buttons -->
            <Border Grid.Row="3" Padding="20,12,20,16">
                <StackPanel x:Name="ButtonPanel" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnSkip" Content="跳過此版本" Margin="0,0,8,0"
                            Style="{StaticResource SecondaryButton}" Click="Skip_Click"/>
                    <Button x:Name="BtnLater" Content="下次再說" Margin="0,0,8,0"
                            Style="{StaticResource SecondaryButton}" Click="Later_Click" IsCancel="True"/>
                    <Button x:Name="BtnUpdate" Content="立即更新" IsDefault="True"
                            Style="{StaticResource PrimaryButton}" Click="Update_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
